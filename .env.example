# Neon PostgreSQL connection string
# Ambil dari Neon Dashboard -> Connection string -> Prisma/Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&channel_binding=require&schema=portfolio"
ADMIN_PASSWORD="change-this-admin-password"
# Optional: gunakan secret berbeda untuk signing cookie admin
ADMIN_SESSION_SECRET="change-this-session-secret"
